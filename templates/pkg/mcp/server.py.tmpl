# ============================================================================
# Diagnostics
# ============================================================================

@mcp.tool()
def health_check() -> str:
    """Report local {{ASSISTANT_NAME}} configuration. Read-only and safe.

    Confirms the note store path and reports which tool categories were
    scaffolded into this server. Changes no external state.
    """
    try:
        store = _note_store()
        existing = store.path.exists()
        count = len(store.list_notes(limit=0)) if existing else 0
        lines = [
            "## {{ASSISTANT_NAME}} health",
            f"- assistant: {{ASSISTANT_NAME}} ({{ASSISTANT_SLUG}})",
            f"- principal: {{PRINCIPAL_NAME}}",
            f"- timezone: {{TIMEZONE}}",
            f"- task system: {{TASK_SYSTEM}}",
            f"- note store: {store.path} ({'present' if existing else 'not created yet'})",
            f"- notes on file: {count}",
            f"- tool categories enabled: {', '.join(ENABLED_CATEGORIES)}",
        ]
        return "\n".join(lines)
    except Exception as e:
        return _format_tool_error(e)


def main() -> None:
    """Run the {{ASSISTANT_NAME}} MCP server over stdio."""
    mcp.run()


if __name__ == "__main__":
    main()
