# {{ASSISTANT_NAME}} environment configuration.
# Copy this file to .env and fill in the placeholders for the categories you enabled.
# .env is gitignored. Never commit real credentials. Keep secrets local.

# Display timezone for dates and scheduling (IANA name).
{{ASSISTANT_SLUG_UPPER}}_TZ={{TIMEZONE}}

# Local directory for runtime state and the notes JSON store.
# Defaults to ./var if unset.
# {{ASSISTANT_SLUG_UPPER}}_VAR_DIR=./var

{{#IF TOOLS_EMAIL}}
# --- Email provider ---
# Path to your email service-account or OAuth credential file (keep under secrets/).
# {{ASSISTANT_SLUG_UPPER}}_EMAIL_CREDENTIALS=secrets/email_credentials.json
# Account address the email tools operate on.
# {{ASSISTANT_SLUG_UPPER}}_EMAIL_ACCOUNT=you@example.com
{{/IF}}
{{#IF TOOLS_CALENDAR}}
# --- Calendar provider ---
# Path to your calendar credential file (may reuse the email credential).
# {{ASSISTANT_SLUG_UPPER}}_CALENDAR_CREDENTIALS=secrets/calendar_credentials.json
# Calendar id the calendar tools default to.
# {{ASSISTANT_SLUG_UPPER}}_CALENDAR_ID=primary
{{/IF}}
{{#IF TOOLS_CHAT}}
# --- Chat provider ({{CHAT_SURFACE}}) ---
# Account or number the chat tools send from.
# {{ASSISTANT_SLUG_UPPER}}_CHAT_ACCOUNT=+10000000000
# Endpoint or socket for the local chat transport, if applicable.
# {{ASSISTANT_SLUG_UPPER}}_CHAT_ENDPOINT=http://127.0.0.1:8080
{{/IF}}
